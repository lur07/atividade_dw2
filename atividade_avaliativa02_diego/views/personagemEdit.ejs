<%- include('partials/header.ejs') %>
<%- include('partials/navbar.ejs') %>

<div class="conteudo">
    <div class="caixa" style="background: white; margin-bottom: 30px;">
        <h1>Editar Habitante de Patópolis</h1>
        <p>Atualize as informações do personagem selecionado.</p>
    </div>

    <div class="caixa" style="max-width: 600px; margin-bottom: 40px; text-align: left;">
        <h2 style="font-size: 24px; font-weight: 900; margin-bottom: 15px; text-align: center;">Alterar Dados</h2>
        
        <form action="/personagens/update" method="POST">
            <input type="hidden" name="id" value="<%= personagem.id %>">

            <div style="margin-bottom: 15px;">
                <label style="font-weight: 800; display: block; margin-bottom: 5px;">Nome do Personagem:</label>
                <input type="text" name="nome" value="<%= personagem.nome %>" required>
            </div>

            <div style="margin-bottom: 15px;">
                <label style="font-weight: 800; display: block; margin-bottom: 5px;">Função / Ocupação:</label>
                <input type="text" name="funcao" value="<%= personagem.funcao %>" required>
            </div>

            <div style="margin-bottom: 20px;">
                <label style="font-weight: 800; display: block; margin-bottom: 5px;">Raridade:</label>
                <input type="text" name="raridade" value="<%= personagem.raridade %>" required>
            </div>

            <button type="submit" class="botao" style="width: 100%; cursor: pointer;">Atualizar Dados</button>
        </form>
    </div>

    <div style="text-align: center;">
        <a href="/personagens" class="botao" style="background: #777; font-size: 16px; padding: 10px 20px;">Voltar para a Lista</a>
    </div>
</div>

<%- include('partials/footer.ejs') %>