<%- include("partials/header") %>
<%- include("partials/navbar") %>

<main class="conteudo">
  <h1>Perfil</h1>

  <div class="cartao-perfil">
    <h2>Dados do Usuário</h2>

    <table class="tabela-perfil" border="1" style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
      <thead>
        <tr style="background-color: #f2f2f2; text-align: left;">
          <th style="padding: 10px;">Campo</th>
          <th style="padding: 10px;">Informação</th>
        </tr>
      </thead>
      <tbody>
        <% perfil.forEach(function(item) { %>
          <tr>
            <td style="padding: 10px;"><strong><%= item.label %>:</strong></td>
            <td style="padding: 10px;"><%= item.valor %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="perfil-botoes">
    <a class="botao" href="/personagens">Personagens</a>
    <a class="botao" href="/">Home</a>
  </div>
</main>

<%- include("partials/footer") %> 